  "title": "SortCriteria",
  "description": "The criteria used to sort.",
  "type": "object",
  "properties": {
    "attributeName": {
      "allOf": [
        {
          "$ref": "#/components/schemas/String"
        },
        {
          "description": "The name of the attribute to sort on."
        }
      ]
    },
    "orderBy": {
      "allOf": [
        {
          "$ref": "#/components/schemas/OrderBy"
        },
        {
          "description": "The sort order, ascending or descending."
        }
      ]
    }
  }
}
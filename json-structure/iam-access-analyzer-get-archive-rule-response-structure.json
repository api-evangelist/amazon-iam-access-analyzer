{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-iam-access-analyzer/refs/heads/main/json-structure/iam-access-analyzer-get-archive-rule-response-structure.json",
  "name": "GetArchiveRuleResponse",
  "description": "The response to the request.",
  "type": "object",
  "properties": {
    "archiveRule": {
      "type": "object",
      "required": [
